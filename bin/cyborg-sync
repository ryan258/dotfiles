#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="${DOTFILES_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
CONFIG_LIB="$DOTFILES_DIR/scripts/lib/config.sh"
COMMON_LIB="$DOTFILES_DIR/scripts/lib/common.sh"

if [[ ! -f "$CONFIG_LIB" ]]; then
    echo "Error: required config library is missing: $CONFIG_LIB" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_LIB"

if [[ -f "$COMMON_LIB" ]]; then
    # shellcheck disable=SC1090
    source "$COMMON_LIB"
fi

WRAPPER_LIB="$DOTFILES_DIR/scripts/lib/wrapper_common.sh"
if [[ -f "$WRAPPER_LIB" ]]; then
    # shellcheck disable=SC1090
    source "$WRAPPER_LIB"
fi

# Daily-hook convention: cyborg-sync has no daily-hook integration, so missing
# sibling always prints the setup message. --help short-circuits to exit 0.
cyborg_sync_unavailable() {
    local expected_home="$1"
    local helper_path="$2"
    local message
    shift 2

    message="Cyborg docs sync is unavailable. Expected sibling repo: $expected_home. Missing helper: $helper_path. Install it there or set CYBORG_HOME/CYBORG_DOCS_SYNC_HELPER."
    echo "$message" >&2

    if wrapper_help_requested "$@"; then
        exit 0
    fi
    exit "${EXIT_FILE_NOT_FOUND:-3}"
}

PROJECTS_DIR="$(wrapper_resolve_safe_path "${PROJECTS_DIR:-$HOME/Projects}" "$HOME")" \
    || exit "${EXIT_INVALID_ARGS:-2}"

CYBORG_HOME="$(wrapper_resolve_safe_path "${CYBORG_HOME:-$PROJECTS_DIR/cyborg-agent}" "$HOME")" \
    || exit "${EXIT_INVALID_ARGS:-2}"

if [[ -n "${CYBORG_DOCS_SYNC_HELPER:-}" ]]; then
    CYBORG_DOCS_SYNC_HELPER="$(wrapper_resolve_safe_path "$CYBORG_DOCS_SYNC_HELPER" "$HOME")" \
        || exit "${EXIT_INVALID_ARGS:-2}"
else
    CYBORG_DOCS_SYNC_HELPER="$CYBORG_HOME/scripts/cyborg_docs_sync.py"
fi

if [[ ! -f "$CYBORG_DOCS_SYNC_HELPER" ]]; then
    cyborg_sync_unavailable "$CYBORG_HOME" "$CYBORG_DOCS_SYNC_HELPER" "$@"
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required. Install Python 3 and retry." >&2
    exit "${EXIT_SERVICE_ERROR:-5}"
fi

export USER_CWD="$(pwd)"
exec python3 "$CYBORG_DOCS_SYNC_HELPER" "$@"
