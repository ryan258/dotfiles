#!/usr/bin/env bash
# cyborg - Shell launcher for the Cyborg Lab ingest agent.
# This small script sets up the environment and then hands off
# to the real Python agent (scripts/cyborg_agent.py).
set -euo pipefail

# Find where this script lives so we can locate sibling files.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# The dotfiles root is one folder up from bin/.
DOTFILES_DIR="${DOTFILES_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"
# We need the shared config library to load .env settings.
CONFIG_LIB="$DOTFILES_DIR/scripts/lib/config.sh"

# Stop early if the config library is missing.
if [[ ! -f "$CONFIG_LIB" ]]; then
    echo "Error: required config library is missing: $CONFIG_LIB" >&2
    exit 1
fi

# Load environment variables (API keys, model names, paths, etc.).
# shellcheck disable=SC1090
source "$CONFIG_LIB"

# The Python agent is the real brain; we cannot run without it.
if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: python3 is required. Install Python 3 and retry." >&2
    exit 1
fi

# Tell the Python agent which directory the user was in when they
# typed the command, so it can find the right repo to scan.
export USER_CWD="$(pwd)"
# Pick the AI model to use from env/config. Prefer an explicit Cyborg
# override, then the content/strategy lanes, then the shared default.
export CYBORG_MODEL="${CYBORG_MODEL:-$(get_model CONTENT)}"

# --- Morphling pre-analysis for autopilot mode (convergence path 1) ---
#
# When the user runs `cyborg auto`, Morphling and Cyborg converge:
# the shell launcher runs Morphling *first* to produce a domain-expert
# analysis of the target repo, then the Python agent uses that analysis
# as additional context for content mapping and drafting.
#
# This block handles convergence path 1 (pre-analysis).  Path 2 (--build)
# is handled entirely inside the Python agent and is mutually exclusive:
# --build skips pre-analysis because there's no repo to analyze yet.
#
# Preconditions for pre-analysis to run:
#   1. Subcommand is "auto" (not "ingest" or "resume")
#   2. Neither --no-morphling nor --build is present
#   3. `uv` is installed (Morphling's dispatcher needs it)
#   4. ai-staff-hq/ submodule exists (Morphling YAML definitions)
#
# The result is exported as CYBORG_MORPHLING_BRIEF.  The Python agent's
# run_autopilot() picks it up and appends it to the session's
# article_text so every AI prompt benefits from the analysis.
# If Morphling fails or returns nothing, we continue silently — the
# pre-analysis is always optional.
if [[ "${1:-}" == "auto" ]]; then
    # Check for flags that make pre-analysis irrelevant.
    # --no-morphling: user explicitly opted out.
    # --build: no repo exists yet; Morphling builds it in the Python agent.
    _skip_morphling=false
    for _arg in "$@"; do
        if [[ "$_arg" == "--no-morphling" || "$_arg" == "--build" ]]; then
            _skip_morphling=true
            break
        fi
    done

    AI_STAFF_DIR="$DOTFILES_DIR/ai-staff-hq"

    if [[ "$_skip_morphling" == "false" ]] \
        && command -v uv >/dev/null 2>&1 \
        && [[ -d "$AI_STAFF_DIR" ]]; then

        # Determine which repo to analyze.  Default to the user's cwd;
        # override with --repo if provided.
        # Handles both '--repo PATH' and '--repo=PATH' syntax so we
        # match whatever argparse would accept on the Python side.
        _morph_repo="$USER_CWD"
        _prev=""
        for _arg in "$@"; do
            if [[ "$_arg" == --repo=* ]]; then
                _morph_repo="${_arg#--repo=}"
                break
            elif [[ "$_prev" == "--repo" ]]; then
                _morph_repo="$_arg"
                break
            fi
            _prev="$_arg"
        done

        # Pipe a structured prompt to morphling.sh in swarm mode so the
        # repo pre-analysis keeps the richer dispatcher context gathering.
        # The default `morphling` path is now direct activate.py, so Cyborg
        # opts into `--swarm` explicitly here. We cd into the target repo so
        # Morphling can read its files. stderr is suppressed to keep the
        # user-facing output clean; the `|| true` ensures a Morphling failure
        # never aborts the launcher (pre-analysis is always best-effort).
        echo "Morphling is pre-analyzing the repo..." >&2
        _morph_brief=$(
            cd "$_morph_repo" 2>/dev/null || cd "$USER_CWD"
            echo "Analyze this repository for a content writer creating Cyborg Lab blog pages. Identify: key concepts, architecture patterns, notable implementation choices, what makes this project interesting, and what would be most valuable to document. Be concise and structured (bullet points). Do not ask follow-up questions." \
                | "$SCRIPT_DIR/morphling.sh" --swarm 2>/dev/null
        ) || true

        # Export the brief so the Python agent can read it from the
        # environment.  If empty, log a skip message but continue — the
        # autopilot pipeline works fine without the pre-analysis.
        if [[ -n "${_morph_brief:-}" ]]; then
            export CYBORG_MORPHLING_BRIEF="$_morph_brief"
            echo "Morphling analysis ready." >&2
        else
            echo "Morphling analysis skipped (no output or unavailable)." >&2
        fi
    fi
fi

# Replace this shell process with the Python agent.
# Any arguments the user typed (like "ingest", "auto", or "resume") pass through.
exec python3 "$DOTFILES_DIR/scripts/cyborg_agent.py" "$@"
