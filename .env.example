# Dotfiles AI Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# OPENROUTER API KEY (REQUIRED)
# ============================================================================
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ============================================================================
# PRIMARY DISPATCHER MODEL CONFIGURATIONS
# ============================================================================
# All dispatchers use a single OpenRouter model by default.
# See available models at: https://openrouter.ai/models

# GLOBAL DEFAULT (used when a dispatcher-specific model is not set)
DEFAULT_MODEL="openrouter/hunter-alpha"

# CYBORG LAB AGENT (cyborg) - Interactive content ingest and rewrite agent
# Fallback chain: CYBORG_MODEL -> CONTENT_MODEL -> STRATEGY_MODEL -> hardcoded default
CYBORG_MODEL="openrouter/hunter-alpha"

# TECH DISPATCHER (tech) - Debugging, code optimization, technical problem-solving
TECH_MODEL="openrouter/hunter-alpha"

# CREATIVE DISPATCHER (creative, copy, narrative) - Story generation, narrative development
CREATIVE_MODEL="openrouter/hunter-alpha"

# CONTENT DISPATCHER (content) - Technical blog posts, documentation, how-to articles
CONTENT_MODEL="openrouter/hunter-alpha"

# STRATEGY DISPATCHER (strategy) - Strategic insights, planning, prioritization
STRATEGY_MODEL="openrouter/hunter-alpha"

# BRAND DISPATCHER (brand) - Optional override (falls back to STRATEGY_MODEL)
# BRAND_MODEL="openrouter/hunter-alpha"

# MARKET DISPATCHER (market) - Long-context market research, competitive analysis
MARKET_MODEL="openrouter/hunter-alpha"

# RESEARCH DISPATCHER (research) - Knowledge synthesis, literature review, organization
RESEARCH_MODEL="openrouter/hunter-alpha"

# STOIC DISPATCHER (stoic) - Mindset coaching, philosophical reasoning
STOIC_MODEL="openrouter/hunter-alpha"

# NARRATIVE DISPATCHER (narrative) - World-building, story structure
# NARRATIVE_MODEL="openrouter/hunter-alpha"

# COPY DISPATCHER (aicopy) - Copywriting, persuasion
# COPY_MODEL="openrouter/hunter-alpha"

# FINANCE DISPATCHER (finance) - Financial analysis, budgeting
# FINANCE_MODEL="openrouter/hunter-alpha"

# MORPHLING DISPATCHER (morphling) - Universal adaptive specialist
MORPHLING_MODEL="openrouter/hunter-alpha"

# ============================================================================
# OPTIONAL AI FEATURES
# ============================================================================
# These features consume API credits when enabled

# AI Daily Briefing in startday.sh
# Provides AI-generated execution coaching grounded in focus + non-fork GitHub activity
# Caches result for the day to avoid multiple API calls
AI_BRIEFING_ENABLED=true
AI_STATUS_ENABLED=false
# Coaching style controls
AI_BRIEFING_TEMPERATURE=0.25
AI_STATUS_TEMPERATURE=0.2
# Daily coach path uses a single direct call, not the full AI-Staff-HQ swarm.
# Set this explicitly if you want a different model than the fast default.
AI_COACH_MODEL="openrouter/hunter-alpha"
# Optional override if you want a custom dispatcher path.
# AI_COACH_DISPATCHER="dhp-coach.sh"

# AI Coach behavior (used by startday + goodevening)
AI_COACH_LOG_ENABLED=true
AI_COACH_TACTICAL_DAYS=7
AI_COACH_PATTERN_DAYS=30
AI_COACH_MODE_DEFAULT=LOCKED
AI_COACH_REQUEST_TIMEOUT_SECONDS=135
AI_COACH_RETRY_ON_TIMEOUT=true
AI_COACH_RETRY_TIMEOUT_SECONDS=300
AI_COACH_DRIFT_STALE_TASK_DAYS=7
AI_COACH_CHAT_ENABLED=true
GITHUB_EXCLUDE_FORKS=true
COACH_LOG_FILE="$HOME/.config/dotfiles-data/coach_log.txt"
COACH_MODE_FILE="$HOME/.config/dotfiles-data/coach_mode.txt"
# Suggestion adherence feedback loop (records daily high/low follow-through)
COACH_ADHERENCE_FILE="$HOME/.config/dotfiles-data/coach_adherence.txt"

# Coaching drift & health thresholds (tune without editing code)
# COACH_DRIFT_STALE_THRESHOLD=4
# COACH_DRIFT_LOW_COMPLETION_THRESHOLD=2
# COACH_DRIFT_UNIQUE_DIRS_THRESHOLD=10
# COACH_DRIFT_SWITCHES_THRESHOLD=80
# COACH_LOW_ENERGY_THRESHOLD=4
# COACH_HIGH_FOG_THRESHOLD=6
# COACH_TREND_DELTA_THRESHOLD=0.2
# COACH_FOCUS_GIT_HIGH_THRESHOLD=60
# COACH_FOCUS_GIT_LOW_THRESHOLD=40
# COACH_FOCUS_ACTIVE_REPO_DRIFT_THRESHOLD=2
# COACH_FOCUS_PRIMARY_REPO_SHARE_THRESHOLD=60

# goodevening project safety scan controls
GOODEVENING_PROJECT_SCAN_LIMIT=20
GOODEVENING_PROJECT_SCAN_JOBS=8
GOODEVENING_PROJECT_ISSUE_DETAIL_LIMIT=8

# AI Daily Reflection in goodevening.sh
# Provides AI-generated reflection on whether the declared focus actually moved
AI_REFLECTION_ENABLED=false

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================
# Your GitHub username, used by scripts/github_helper.sh for portability.
# If not set, scripts will attempt to use 'git config user.name'.
GITHUB_USERNAME=""
# Optional overrides for token/cache paths used by GitHub helpers.
# GITHUB_TOKEN_FILE="$HOME/.github_token"
# GITHUB_TOKEN_FALLBACK="$HOME/.config/dotfiles-data/github_token"
# GITHUB_CACHE_DIR="$HOME/.config/dotfiles-data/cache/github"

# ============================================================================
# PACKAGE REGISTRY TOKENS (for cyborg auto --build --publish)
# ============================================================================
# npm registry token.  Generate at https://www.npmjs.com/settings/tokens
# NPM_TOKEN=""
# PyPI credentials.  Use __token__ as username with an API token as password.
# Generate at https://pypi.org/manage/account/token/
# TWINE_USERNAME="__token__"
# TWINE_PASSWORD=""
# Cargo (crates.io) registry token.  Generate at https://crates.io/settings/tokens
# CARGO_REGISTRY_TOKEN=""

# ============================================================================
# FITBIT SYNC VIA GOOGLE HEALTH API
# ============================================================================
# Used by scripts/fitbit_sync.sh. Register a Google Cloud OAuth client, add
# the needed Google Health API scopes, and keep in mind that testing-mode
# refresh tokens can expire after 7 days.
GOOGLE_HEALTH_CLIENT_ID="your-client-id"
GOOGLE_HEALTH_CLIENT_SECRET="your-client-secret"
GOOGLE_HEALTH_REDIRECT_URI="https://www.google.com"
GOOGLE_HEALTH_SCOPES="https://www.googleapis.com/auth/googlehealth.activity_and_fitness.readonly https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly https://www.googleapis.com/auth/googlehealth.sleep.readonly"
GOOGLE_HEALTH_DEFAULT_DAYS=14

# ============================================================================
# GOOGLE DRIVE STRATEGY SIGNALS (OPTIONAL)
# ============================================================================
# Used by scripts/drive.sh and the daily coach's strategy-evidence scan.
# This is a read-only Google Drive desktop-app loopback auth path.
# - `drive.sh recent` is the best-effort recent-doc signal used by the coach.
# - `drive.sh recall` is the manual "don't reinvent prior work" search path.
# Register a Google OAuth client for a "Desktop app".
# GOOGLE_DRIVE_CLIENT_ID="your-drive-client-id"
# GOOGLE_DRIVE_CLIENT_SECRET="your-drive-client-secret"
# GOOGLE_DRIVE_DEFAULT_DAYS=7
# GDRIVE_CONNECT_TIMEOUT_SECONDS=5
# GDRIVE_MAX_TIME_SECONDS=20
# GDRIVE_CREDS_FILE="$HOME/.config/dotfiles-data/google_drive_creds.json"
# GDRIVE_TOKEN_FILE="$HOME/.config/dotfiles-data/google_drive_token_cache.json"
# GDRIVE_CACHE_FILE="$HOME/.cache/dotfiles/google_drive_search_cache.json"

# ============================================================================
# SCRIPT CONFIGURATION
# ============================================================================
# Number of days after which a completed task is considered stale and can be cleaned up.
STALE_TASK_DAYS=7
# Maximum number of suggestions to display in scripts like g.sh.
MAX_SUGGESTIONS=10
# Number of days to look back for the weekly review script.
REVIEW_LOOKBACK_DAYS=7

# Minimum delay in seconds between API calls to prevent hitting rate limits.
# Set to 0 to disable cooldown.
API_COOLDOWN_SECONDS=1

# Backup destinations (override the defaults in config.sh if needed)
# DOTFILES_BACKUP_DIR="$HOME/Backups/dotfiles_data"
# DOTFILES_BACKUP_GDRIVE_REMOTE="gdrive"
# DOTFILES_BACKUP_GDRIVE_FOLDER="Backups/dotfiles_data"
# PROJECT_BACKUP_DIR="$HOME/Backups"
# PROJECT_BACKUP_GDRIVE_REMOTE="gdrive"
# PROJECT_BACKUP_GDRIVE_BASE_FOLDER="Backups"

# ============================================================================
# CYBORG LAB AGENT (OPTIONAL)
# ============================================================================
# Settings specific to the `cyborg` ingest/resume agent (bin/cyborg).

# Path to the Cyborg Lab Hugo blog repo (must contain a content/ directory).
# If unset, cyborg auto-discovers from known paths or prompts interactively.
# CYBORG_LAB_DIR="$HOME/Projects/cyborg/my-ms-ai-blog"

# Workspace for Cyborg session artifacts (resume state, transcripts, previews).
# Defaults to ~/Projects/cyborg-work when unset.
# CYBORG_WORK_DIR="$HOME/Projects/cyborg-work"

# Force deterministic mode (no AI calls) for the cyborg agent.
# Useful for offline work or testing. Set to true/1/yes to enable.
# CYBORG_DISABLE_AI=false

# Disable the GitNexus integration entirely and stay with native scanning.
# Set to true/1/yes to disable.
# CYBORG_DISABLE_GITNEXUS=false

# ============================================================================
# BLOG & OUTPUT DIRECTORIES (OPTIONAL)
# ============================================================================
# Configure these if you use the blog or creative writing workflows

# Blog Directory - Enable blog workflow commands (startday/blog.sh)
# Set this to your personal blog repository to keep paths user-specific
BLOG_DIR=""
if [ -n "${BLOG_DIR:-}" ]; then
  BLOG_CONTENT_DIR="$BLOG_DIR/content"
  BLOG_ARCHETYPES_DIR="$BLOG_DIR/archetypes"
  BLOG_STANDARDS_FILE="$BLOG_DIR/GUIDE-WRITING-STANDARDS.md"
  BLOG_CONTRIBUTING_FILE="$BLOG_DIR/CONTRIBUTING.md"
fi
BLOG_STATUS_REVIEW_DETAIL_LIMIT=5

# Section exemplar mapping (section_prefix|relative_path). Customize per repo.
if [ -z "${BLOG_SECTION_EXEMPLARS:-}" ]; then
BLOG_SECTION_EXEMPLARS=$(cat <<'EOF'
guides/ai-frameworks|content/guides/ai-frameworks/advanced-prompting.md
guides/brain-fog|content/guides/brain-fog/daily-briefing.md
guides/keyboard-efficiency|content/guides/keyboard-efficiency/core-5-shortcuts.md
guides/productivity-systems|content/guides/productivity-systems/prompt-versioning.md
blog|content/blog/automation-and-disability.md
prompts|content/prompts/bluf-decision-prompt.md
shortcuts/automations|content/shortcuts/automations/ai-summary-spotlight.md
shortcuts/keyboard-shortcuts|content/shortcuts/keyboard-shortcuts/core-5-spotlight.md
shortcuts/system-instructions|content/shortcuts/system-instructions/brain-fog-assistant-persona.md
EOF
)
fi

# Dispatcher Output Directories
# Where generated content from each dispatcher should be saved.
# The default structure is provided below. You can customize these paths.
if [ -z "${DHP_BRAND_OUTPUT_DIR:-}" ]; then
  DHP_BRAND_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Strategy/Brand/"
fi
if [ -z "${DHP_CONTENT_OUTPUT_DIR:-}" ]; then
  DHP_CONTENT_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Content/Guides/"
fi
DHP_COPY_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Creative/Copywriting/"
DHP_CREATIVE_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Creative/Stories/"
DHP_MARKET_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Strategy/Market_Research/"
DHP_NARRATIVE_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Creative/Narratives/"
DHP_RESEARCH_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Personal_Development/Research/"
DHP_STOIC_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Personal_Development/Stoic_Coaching/"
DHP_STRATEGY_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Strategy/Analysis/"
DHP_TECH_OUTPUT_DIR="$HOME/Documents/AI_Staff_HQ_Outputs/Technical/Code_Analysis/"

# Optional swipe logging (capture command output to markdown)
SWIPE_LOG_ENABLED=false
SWIPE_LOG_FILE="$HOME/Documents/swipe.md"


# ============================================================================
# NOTES
# ============================================================================
#
# Model Selection Guide:
# - Free models are excellent for most tasks and won't incur charges
# - Paid models (GPT-4o, Claude Opus) offer higher quality but cost per use
# - You can mix free and paid models based on your needs
#
# Cost Management:
# - All default models above are FREE on OpenRouter
# - Monitor usage at: https://openrouter.ai/activity
# - Set spending limits in your OpenRouter account
#
# Customization:
# - Change any model to your preference
# - Test different models for your specific use cases
# - See model details: https://openrouter.ai/models
#
# Documentation:
# - Dispatcher details: ~/dotfiles/bin/README.md
# - Full changelog: ~/dotfiles/CHANGELOG.md
# - Implementation roadmap: ~/dotfiles/ROADMAP.md
